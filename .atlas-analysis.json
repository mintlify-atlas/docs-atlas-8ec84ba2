  "keyFeatures": [
    "Bluetooth Low Energy device scanning and connection",
    "Wildlife camera device management and configuration",
    "Project and deployment tracking with map integration",
    "Firmware over-the-air updates (DFU)",
    "Real-time sensor data and observations",
    "OAuth authentication and user management",
    "Offline-capable data synchronization"
  ],
  "publicApiSurface": [
    "useBle() - BLE connection and communication hook",
    "useCommand() - Device command execution hook",
    "useBleActions() - BLE provider context",
    "devicesApi - RTK Query API for device management",
    "projectsApi - RTK Query API for project management",
    "deploymentsApi - RTK Query API for deployment tracking",
    "observationsApi - RTK Query API for wildlife observations",
    "CommandNames - Available device commands (ID, VERSION, BATTERY, SENSOR, etc.)",
    "DfuService - Firmware update service",
    "WWButton, WWText, WWIcon - UI component library"
  ]
